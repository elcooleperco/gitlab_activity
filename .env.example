# GitLab
GITLAB_URL=http://gitlab.local
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gitlab_analyzer
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/gitlab_analyzer

# Redis
REDIS_URL=redis://redis:6379/0

# Приложение
LOG_LEVEL=INFO

# Порт frontend (по умолчанию 3000)
FRONTEND_PORT=3000

# DNS сервер для контейнеров (по умолчанию Google DNS)
DNS=8.8.8.8
